<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shift_template_tree" model="ir.ui.view">
        <field name="name">shift.template.tree</field>
        <field name="model">shift.template</field>
        <field name="arch" type="xml">
            <tree string="Vardiya Şablonları" decoration-muted="active==False">
                <field name="name"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="analytic_account_id"/>
                <field name="color"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_shift_template_form" model="ir.ui.view">
        <field name="name">shift.template.form</field>
        <field name="model">shift.template</field>
        <field name="arch" type="xml">
            <form string="Vardiya Şablonu">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="analytic_account_id"/>
                            <field name="color"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
