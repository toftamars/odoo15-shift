<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shift_schedule_tree" model="ir.ui.view">
        <field name="name">shift.schedule.tree</field>
        <field name="model">shift.schedule</field>
        <field name="arch" type="xml">
            <tree string="Vardiya Planları">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="analytic_account_id"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_shift_schedule_calendar" model="ir.ui.view">
        <field name="name">shift.schedule.calendar</field>
        <field name="model">shift.schedule</field>
        <field name="arch" type="xml">
            <calendar string="Vardiya Planları" date_start="date_start" date_stop="date_end" mode="month">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
                <field name="analytic_account_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_shift_schedule_form" model="ir.ui.view">
        <field name="name">shift.schedule.form</field>
        <field name="model">shift.schedule</field>
        <field name="arch" type="xml">
            <form string="Vardiya Planı">
                <header>
                    <button name="action_confirm" string="Onayla" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}" groups="shift.group_shift_manager"/>
                    <button name="action_done" string="Tamamla" type="object"
                            attrs="{'invisible': [('state', '!=', 'confirmed')]}" groups="shift.group_shift_manager"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="analytic_account_id"/>
                            <field name="user_ids" widget="many2many_tags"
                                  domain="[('share', '=', False)]"
                                  attrs="{'invisible': [('analytic_account_id', '=', False)]}"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Vardiya Atamaları" name="assignments">
                            <field name="assignment_ids" readonly="1">
                                <tree create="false" delete="false" edit="false">
                                    <field name="employee_id"/>
                                    <field name="analytic_account_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
