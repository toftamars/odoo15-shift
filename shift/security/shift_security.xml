<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Shift Kullanıcı Grubu - Tüm iç kullanıcılara otomatik atanır -->
        <record id="group_shift_user" model="res.groups">
            <field name="name">Shift Kullanıcı</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="comment">Vardiya planlaması görüntüleme ve atama yapabilir</field>
        </record>

        <!-- Shift Yönetici Grubu -->
        <record id="group_shift_manager" model="res.groups">
            <field name="name">Shift Yönetici</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_shift_user'))]"/>
            <field name="comment">Vardiya şablonları ve planları oluşturabilir, silebilir</field>
        </record>

        <!-- İç kullanıcılara (base.group_user) otomatik shift erişimi -->
        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('shift.group_shift_user'))]"/>
        </record>

    </data>
</odoo>
